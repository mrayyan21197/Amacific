# Copy to .env.local for local development (never commit secrets)

# Mailchimp embedded form POST URL (Audience > signup forms > embedded form code)
REACT_APP_MAILCHIMP_FORM_ACTION=

# Optional Mailchimp hidden field names (defaults work for standard embed)
# REACT_APP_MAILCHIMP_U=
# REACT_APP_MAILCHIMP_ID=

# GA4 Measurement ID
REACT_APP_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel ID
REACT_APP_META_PIXEL_ID=

# TikTok Pixel ID
REACT_APP_TIKTOK_PIXEL_ID=

# Microsoft Clarity ID
REACT_APP_CLARITY_PROJECT_ID=
